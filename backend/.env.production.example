# Cloud Run Production Environment Variables
# Copy this to .env.production in Cloud Run settings

# JWT
SECRET_KEY=your-jwt-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@gmail.com
SMTP_APP_PASSWORD=your-app-password-here

# Google Calendar API
GOOGLE_CLIENT_ID=your-client-id-here
GOOGLE_CLIENT_SECRET=your-client-secret-here
GOOGLE_REDIRECT_URI=https://your-cloud-run-url/api/auth/google/callback
GOOGLE_REFRESH_TOKEN=your-refresh-token-here

# Database (Cloud SQL)
# Format: postgresql://username:password@cloudsql-proxy-host/database
DATABASE_URL=postgresql://user:password@cloudsql-proxy/bni47_passport

# Frontend URL
FRONTEND_URL=https://bni-chapter47-passport-app.web.app

# Encryption Key (32-byte base64)
ENCRYPTION_KEY=your-32-byte-encryption-key-base64-here
