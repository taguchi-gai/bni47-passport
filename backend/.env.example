# JWT
SECRET_KEY=your-secret-key-here-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Gmail SMTP（App Password方式 - OAuthトークン不要）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-system-gmail@gmail.com
SMTP_APP_PASSWORD=your-16-digit-app-password

# Google Calendar API（システムアカウント用 - 1つだけ管理）
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
GOOGLE_REFRESH_TOKEN=your-system-google-refresh-token

# 暗号化キー（メンターのZoom URL等の暗号化）
ENCRYPTION_KEY=your-32-byte-encryption-key-base64

# DB
DATABASE_URL=sqlite:///./bni_passport.db

# フロントエンドURL
FRONTEND_URL=http://localhost:5173
